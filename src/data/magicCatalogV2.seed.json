      "requiredGeometry": "straight_or_curved_radial",
      "straightLineAllowed": true,
      "straightLinePenalty": 0
    },
    "outerCircleCrossing": "invalid_or_leak_failure",
    "endpointSnapRadiusRatio": 0.1
